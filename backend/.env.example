# 后端环境变量配置
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ========================================
# 服务器配置
# ========================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ========================================
# AI API Keys (至少需要一个)
# ========================================
# OpenAI API Key - 用于报告生成
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Mimo API Key - 用于贡献评分
# 获取地址: https://platform.xiaomimimo.com
MIMO_API_KEY=your_mimo_api_key_here

# ========================================
# GitHub API (可选 - 用于采集贡献数据)
# ========================================
# 获取地址: https://github.com/settings/tokens
# 需要权限: repo, read:user
GITHUB_TOKEN=github_pat_your_token_here

# ========================================
# Cobo Agentic Wallet (可选 - 用于链上结算)
# ========================================
# 获取地址: https://developers.cobo.com/
COBO_API_KEY=
COBO_API_SECRET=
COBO_BASE_URL=https://api.cobo.com
CHAIN_ID=11155111

# ========================================
# 区块链配置 (可选 - 用于链上结算)
# ========================================
# Infura/Alchemy RPC URL
# RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# 部署者钱包私钥 (不要分享!)
# PRIVATE_KEY=your_private_key_here

# 已部署的合约地址
# CONTRACT_ADDRESS=0x_your_contract_address_here

# Sepolia USDC 代币地址
# PAYMENT_TOKEN_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
